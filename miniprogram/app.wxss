page {
  min-height: 100%;
  background: #f7faf8;
  color: #15231d;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

.page {
  min-height: 100vh;
  padding: 28rpx;
  box-sizing: border-box;
}

.stack {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.panel {
  background: #ffffff;
  border: 1rpx solid #e1e8e3;
  border-radius: 16rpx;
  padding: 28rpx;
  box-shadow: 0 10rpx 30rpx rgba(35, 61, 49, 0.06);
}

.panel-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 18rpx;
}

.h1 {
  font-size: 48rpx;
  font-weight: 700;
  line-height: 1.12;
}

.h2 {
  font-size: 32rpx;
  font-weight: 700;
}

.eyebrow {
  color: #597064;
  font-size: 24rpx;
  margin-bottom: 8rpx;
}

.muted {
  color: #6b756f;
  font-size: 25rpx;
  line-height: 1.5;
}

.primary-button,
.secondary-button,
.danger-button {
  border-radius: 12rpx;
  font-size: 28rpx;
  line-height: 1;
  padding: 24rpx 28rpx;
}

.primary-button {
  background: #166a54;
  color: #ffffff;
}

.secondary-button {
  background: #edf4f0;
  color: #166a54;
}

.danger-button {
  background: #fff1ef;
  color: #af3428;
}

.field {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.field text {
  color: #43564c;
  font-size: 25rpx;
}

.field input,
.field textarea {
  width: 100%;
  min-height: 78rpx;
  border: 1rpx solid #d7e1db;
  border-radius: 12rpx;
  background: #fbfdfb;
  padding: 18rpx 20rpx;
  box-sizing: border-box;
  font-size: 28rpx;
}

.field textarea {
  min-height: 140rpx;
}
