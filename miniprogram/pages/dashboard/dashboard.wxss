.hero-panel {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.hero-copy {
  margin-bottom: 10rpx;
}

.brand-lockup {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.brand-icon {
  width: 76rpx;
  height: 76rpx;
  border-radius: 18rpx;
  flex: 0 0 auto;
}

.brand-title {
  color: #15231d;
  font-size: 36rpx;
  font-weight: 800;
  line-height: 1.15;
}

.compact-button {
  min-width: 132rpx;
  padding-left: 18rpx;
  padding-right: 18rpx;
}

.metric-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.metric-grid > view {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  background: #f4f8f6;
  border-radius: 12rpx;
  padding: 18rpx;
}

.metric-value {
  font-size: 30rpx;
  font-weight: 700;
}

.bars {
  height: 220rpx;
  display: flex;
  align-items: flex-end;
  gap: 12rpx;
  padding-top: 16rpx;
}

.bar-item {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.bar {
  width: 100%;
  min-height: 16rpx;
  max-width: 34rpx;
  border-radius: 12rpx 12rpx 4rpx 4rpx;
  background: linear-gradient(180deg, #3fb28c, #166a54);
}

.bar-value,
.bar-date {
  color: #60736a;
  font-size: 20rpx;
}

.prediction-row {
  display: flex;
  justify-content: space-between;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #edf1ee;
  font-size: 26rpx;
}

.empty,
.error-text {
  color: #af3428;
  font-size: 26rpx;
}
