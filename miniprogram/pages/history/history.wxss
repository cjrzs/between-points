.page-title {
  margin-bottom: 4rpx;
}

.compact-button {
  min-width: 120rpx;
  padding-left: 18rpx;
  padding-right: 18rpx;
}

.record-card {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.record-date {
  font-size: 30rpx;
  font-weight: 700;
}

.record-weight {
  color: #166a54;
  font-size: 34rpx;
  font-weight: 700;
}

.record-meta {
  display: flex;
  gap: 16rpx;
  color: #60736a;
  font-size: 24rpx;
}

.note {
  background: #f4f8f6;
  border-radius: 12rpx;
  color: #43564c;
  font-size: 25rpx;
  line-height: 1.5;
  padding: 18rpx;
}

.empty-panel {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
