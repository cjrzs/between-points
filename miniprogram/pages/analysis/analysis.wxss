.summary-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 14rpx;
  margin: 24rpx 0;
}

.summary-grid > view {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  background: #f4f8f6;
  border-radius: 12rpx;
  padding: 16rpx;
}

.summary-value {
  font-size: 28rpx;
  font-weight: 700;
}

.prediction-card {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #edf1ee;
}

.prediction-top,
.tag-impact {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
  font-size: 26rpx;
}

.prediction-top text:last-child,
.tag-impact text:last-child {
  color: #166a54;
  font-weight: 700;
}
